# SSGhub Mail Production Optimized Configuration

# Database Configuration (Optimized)
DB_PASSWORD=${SECURE_DB_PASSWORD}
DB_HOST=postgres
DB_PORT=5432
DB_NAME=ssgzone_mail
DB_USER=ssgzone
DB_MAX_CONNECTIONS=20
DB_IDLE_TIMEOUT=30050

# Redis Configuration (Optimized)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_MAX_RETRIES=3
REDIS_RETRY_DELAY=100

# Security Configuration
JWT_SECRET=${SECURE_JWT_SECRET}
ENCRYPTION_KEY=${SECURE_ENCRYPTION_KEY}
CSRF_SECRET=${SECURE_CSRF_SECRET}
SESSION_SECRET=${SECURE_SESSION_SECRET}

# Authentication Tokens (Environment-based)
TEST_TOKEN=${SECURE_TEST_TOKEN}
TENANT_ADMIN_TOKEN=${SECURE_TENANT_ADMIN_TOKEN}
SUPER_ADMIN_TOKEN=${SECURE_SUPER_ADMIN_TOKEN}

# Rate Limiting (Optimized)
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=1000
RATE_LIMIT_SKIP_SUCCESSFUL_REQUESTS=true

# Performance Configuration
NODE_ENV=production
COMPRESSION_ENABLED=true
CACHE_TTL=3600
MAX_REQUEST_SIZE=10mb

# SSL/TLS Configuration
SSL_ENABLED=true
SSL_CERT_PATH=/etc/ssl/certs/ssgzone.in.crt
SSL_KEY_PATH=/etc/ssl/private/ssgzone.in.key
FORCE_HTTPS=true

# Monitoring & Logging
LOG_LEVEL=warn
METRICS_ENABLED=true
AUDIT_ENABLED=true
HEALTH_CHECK_INTERVAL=30050

# DNS Manager Configuration
DNS_PORT=3005
CLOUDFLARE_API_TOKEN=${SECURE_CLOUDFLARE_TOKEN}
AWS_ACCESS_KEY_ID=${SECURE_AWS_ACCESS_KEY}
AWS_SECRET_ACCESS_KEY=${SECURE_AWS_SECRET_KEY}
AWS_REGION=us-east-1

# Mail Server Configuration
DOMAIN=ssgzone.in
SMTP_HOST=mail-server
SMTP_PORT=587
DKIM_PRIVATE_KEY_PATH=/etc/dkim/ssgzone.in.private
DKIM_SELECTOR=default

# Object Storage Configuration
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=${SECURE_MINIO_ACCESS_KEY}
MINIO_SECRET_KEY=${SECURE_MINIO_SECRET_KEY}
MINIO_BUCKET=ssgzone-attachments
MAX_ATTACHMENT_SIZE=104857600

# Search Configuration
ELASTICSEARCH_HOST=elasticsearch:9200
ELASTICSEARCH_MAX_RETRIES=3

# Calendar Service
CALENDAR_PORT=4003

# IP Warmup Service
WARMUP_SERVICE_URL=http://ip-warmup-service:3004