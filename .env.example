# Database Configuration
DB_PASSWORD=your_secure_password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ssgzone_mail
DB_USER=ssgzone

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# Mail Server Configuration
DOMAIN=ssgzone.in
SMTP_HOST=localhost
SMTP_PORT=587

# API Configuration
JWT_SECRET=your_jwt_secret_key
API_PORT=4000
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100

# DNS Manager Configuration
DNS_PORT=3005
CLOUDFLARE_API_TOKEN=your_cloudflare_token
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1

# Calendar Service Configuration
CALENDAR_PORT=4003

# IP Warmup Service
WARMUP_SERVICE_URL=http://ip-warmup-service:3004

# Security
ENCRYPTION_KEY=your_32_character_encryption_key
ADMIN_EMAIL=admin@ssgzone.in
ADMIN_PASSWORD=secure_admin_password

# SSL/TLS Configuration
SSL_ENABLED=false
SSL_CERT_PATH=/etc/ssl/certs/ssgzone.in.crt
SSL_KEY_PATH=/etc/ssl/private/ssgzone.in.key
DKIM_PRIVATE_KEY_PATH=/etc/dkim/ssgzone.in.private
DKIM_SELECTOR=default

# Object Storage (MinIO)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=ssgzone-attachments
MAX_ATTACHMENT_SIZE=104857600

# Elasticsearch
ELASTICSEARCH_HOST=localhost:9200

# Data Retention
DEFAULT_RETENTION_DAYS=2555
DEFAULT_ARCHIVE_DAYS=365
RETENTION_JOB_ENABLED=true

# Monitoring
LOG_LEVEL=info
METRICS_ENABLED=true
HEALTH_CHECK_INTERVAL=30050